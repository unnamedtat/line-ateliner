{
  "name": "line-atelier",
  "version": "0.1.0",
  "private": true,
  "description": "A browser-based line art and paper texture playground built with p5.js.",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --config vitest.config.mjs --configLoader runner",
    "test:e2e": "playwright test",
    "postinstall": "node ./scripts/sync-vendor.mjs"
  },
  "dependencies": {
    "gif.js.optimized": "^1.0.1",
    "p5": "1.11.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.7.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
